---
import { Image } from 'astro:assets';
import '../styles/global.css'; // This links your new CSS file

// Import all 5 of your images
import img1 from '../assets/drinks.png';
import img2 from '../assets/english breakfasts.png';
import img3 from '../assets/main meals.png';
import img4 from '../assets/rolls and wraps.png';
import img5 from '../assets/loaded chips.png';

const images = [img1, img2, img3, img4, img5];
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Beach Hut Cafe</title>
  </head>
  <body>
<div class="image-stack">
  {images.map((pic, index) => (
    <Image 
      src={pic} 
      alt={`Beach Hut Cafe photo ${index + 1}`} 
      class="responsive-img"
    />
  ))}
</div>

<div id="announcement-modal" class="modal-overlay">
  <div class="modal-content">
    <button id="close-modal" class="close-btn">&times;</button>
    <h2>Hello</h2>
    <p>Prices may vary from this website.</p>
    <p>Some items are only available in the mornings/afternoons.</p>
    <button id="close-btn-main" class="ok-btn">Understood</button>
  </div>
</div>

<script src="../scripts/modal.js"></script>
</body>
</html>